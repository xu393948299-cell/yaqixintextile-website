{
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/GG-optimized-v9-denim-seo.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/about-us.html",
      "destination": "/custom-capability.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/yaqixin-assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
